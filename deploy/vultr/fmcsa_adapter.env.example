# FAXP FMCSA adapter - Vultr environment example

# Adapter listener (bind localhost; Caddy terminates TLS)
FAXP_ADAPTER_HOST=127.0.0.1
FAXP_ADAPTER_PORT=8088
FAXP_ADAPTER_ENDPOINT=/v1/fmcsa/verify
FAXP_ADAPTER_HEALTH_ENDPOINT=/healthz
FAXP_ADAPTER_REQUIRE_AUTH=1
FAXP_ADAPTER_DEBUG=0

# Shared bearer token (also set this value in Streamlit secret FAXP_FMCSA_ADAPTER_AUTH_TOKEN)
FAXP_FMCSA_ADAPTER_AUTH_TOKEN=replace_with_strong_random_token

# FMCSA direct API credentials
FAXP_FMCSA_WEBKEY=replace_with_fmcsa_webkey
FAXP_FMCSA_CLIENT_SECRET=replace_with_fmcsa_client_secret
FAXP_FMCSA_API_BASE_URL=https://mobile.fmcsa.dot.gov/qc/services
FAXP_FMCSA_API_TIMEOUT_SECONDS=12
FAXP_FMCSA_LOG_UNKNOWN_KEYS=1
FAXP_FMCSA_EXPECTED_TOP_LEVEL_KEYS=content,result,data,error,errors

# Verifier wrapper signature (must match FAXP verifier trust config in Streamlit/simulation)
FAXP_VERIFIER_SIGNATURE_SCHEME=ED25519
FAXP_VERIFIER_ED25519_ACTIVE_KEY_ID=verifier-20260220191222
FAXP_VERIFIER_ED25519_PRIVATE_KEYS=verifier-20260220191222:/opt/faxp/keys/verifier-20260220191222-private.pem
FAXP_VERIFIER_ED25519_PUBLIC_KEYS=verifier-20260220191222:/opt/faxp/keys/verifier-20260220191222-public.pem

# Alternative HMAC mode:
# FAXP_VERIFIER_SIGNATURE_SCHEME=HMAC_SHA256
# FAXP_VERIFIER_SIGNING_ACTIVE_KEY_ID=verifier-20260220191222
# FAXP_VERIFIER_SIGNING_KEYS=verifier-20260220191222:replace_with_hex_or_ascii_key
