{
  "profileVersion": "1.0.0",
  "profileId": "operational-handoff-metadata.v1",
  "protocol": "FAXP",
  "scope": "booking-plane-operational-handoff",
  "description": "Canonical optional post-booking operational handoff metadata profile for routing a confirmed booking into the correct downstream workflow without moving dispatch into protocol core.",
  "executionReportField": "OperationalHandoff",
  "bookingIdentityAssumptions": {
    "envelopeFields": [
      "From",
      "To"
    ],
    "executionReportFields": [
      "LoadID|TruckID",
      "ContractID"
    ],
    "optionalCorrelationField": "LoadReferenceNumbers"
  },
  "operationalHandoff": {
    "requiredFields": [
      "OperationalReference",
      "SystemOfRecordType",
      "SystemOfRecordRef",
      "SetupStatus"
    ],
    "optionalFields": [
      "HandoffEndpointType",
      "HandoffEndpointRef",
      "SupportedHandoffActions"
    ],
    "systemOfRecordTypes": [
      "TMS",
      "LoadBoard",
      "BrokerPortal",
      "CarrierPortal",
      "ShipperPortal",
      "InternalQueue",
      "ManualWorkflow"
    ],
    "handoffEndpointTypes": [
      "A2A",
      "Webhook",
      "Portal",
      "Email",
      "InternalQueue",
      "ManualWorkflow"
    ],
    "supportedHandoffActions": [
      "GenerateRateConfirmation",
      "SendRateConfirmation",
      "RequestCarrierSetup",
      "RetrieveDispatchInstructions",
      "AcknowledgeBooking",
      "ManualFollowUp"
    ],
    "setupStatuses": [
      "Known",
      "Required",
      "Expired",
      "Unknown"
    ]
  },
  "normativeConstraints": {
    "routingIntentOnly": true,
    "bookingIdentityMustRemainExplicit": true,
    "manualFallbackRemainsConformant": true,
    "dispatchPacketContentOutOfScope": true,
    "operationalExecutionStateOutOfScope": true,
    "setupStatusMayDriveAutomationPolicy": true
  },
  "conformanceRequirements": {
    "requiredTests": [
      "tests/run_operational_handoff_terms.py",
      "tests/run_operational_handoff_profile.py"
    ],
    "requiredSuiteChecks": [
      "operational_handoff_terms",
      "operational_handoff_profile"
    ]
  }
}
