{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faxp.org/schema/adapter-test-profile-v1.json",
  "title": "FAXP Adapter Test Profile",
  "type": "object",
  "required": [
    "profileId",
    "version",
    "provider",
    "providerId",
    "requestContract",
    "responseContract",
    "securityRequirements",
    "certificationChecks"
  ],
  "properties": {
    "profileId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "providerId": {
      "type": "string"
    },
    "requestContract": {
      "type": "object",
      "required": [
        "method",
        "path",
        "contentType",
        "requiredBodyFields"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["POST"]
        },
        "path": {
          "type": "string"
        },
        "contentType": {
          "type": "string",
          "const": "application/json"
        },
        "requiredBodyFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "responseContract": {
      "type": "object",
      "required": [
        "wrapperRequired",
        "signatureRequired",
        "requiredTopLevelFields",
        "verificationResultFields",
        "providerExtensionsFields",
        "legacyNormalizedFields"
      ],
      "properties": {
        "wrapperRequired": {
          "type": "boolean"
        },
        "signatureRequired": {
          "type": "boolean"
        },
        "requiredTopLevelFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verificationResultFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "providerExtensionsFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "legacyNormalizedFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "securityRequirements": {
      "type": "object",
      "required": [
        "signedRequests",
        "signedResponses",
        "nonceReplayProtection",
        "maxClockSkewSeconds"
      ],
      "properties": {
        "signedRequests": {
          "type": "boolean"
        },
        "signedResponses": {
          "type": "boolean"
        },
        "nonceReplayProtection": {
          "type": "boolean"
        },
        "maxClockSkewSeconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "certificationChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

